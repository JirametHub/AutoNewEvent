-- [[ โหลดสถานะ Party ที่ซ่อนไว้เพื่อกู้คืนอัตโนมัติ ]] --
task.spawn(function()
    task.wait(2)
    pcall(function()
        if isfile and isfile("JirametHubConfig/Party_State.json") and readfile then
            local state = HttpService:JSONDecode(readfile("JirametHubConfig/Party_State.json"))
            if state and state.Token and state.Token ~= "" then
                local data = ReadFirebase("Parties/" .. state.Token)
                if data then
                    CurrentToken = state.Token
                    IsHost = state.IsHost
                    PartyData = data
                    
                    if not IsHost then
                        local membersList = {}
                        if type(data.Members) == "table" then
                            for _, v in pairs(data.Members) do
                                table.insert(membersList, v)
                            end
                        end
                        
                        local found = false
                        for _, v in pairs(membersList) do
                            if v == player.Name then found = true end
                        end
                        if not found then
                            table.insert(membersList, player.Name)
                            data.Members = membersList
                            WriteFirebase("Parties/" .. CurrentToken, data)
                        end
                    else
                        data.JobId = game.JobId
                        data.PlaceId = game.PlaceId
                        data.IsInLobby = isInLobby()
                        WriteFirebase("Parties/" .. CurrentToken, data)
                    end
                    
                    Fluent:Notify({ Title = "Party Restored", Content = "Party connection restored!", Duration = 3 })
                end
            end
        end
    end)
    -- ปลดล็อกให้ระบบ Auto Join ทำงานได้ หลังจากโหลดเซฟเสร็จ
    IsPartyLoaded = true 
end)

