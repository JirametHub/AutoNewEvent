    BlackScreenBtn.Name = "ToggleBlackScreenBtn"
    BlackScreenBtn.Position = UDim2.new(0.5, -75, 0, 15) 
    BlackScreenBtn.Size = UDim2.new(0, 150, 0, 35)
    BlackScreenBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    BlackScreenBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    BlackScreenBtn.Text = "Black Screen: OFF"
    BlackScreenBtn.Font = Enum.Font.GothamBold
    BlackScreenBtn.TextSize = 14
    BlackScreenBtn.ZIndex = 2 
    BlackScreenBtn.Visible = false 
    BlackScreenBtn.Parent = BlackScreenGui
    
    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 8)
    BtnCorner.Parent = BlackScreenBtn

    local isBlackScreenOn = false

    local ShowBlackScreenBtnToggle = Tabs.Settings:AddToggle("ShowBlackScreenBtn", {Title = "Show Black Screen Button", Default = false })

    local function toggleBlackScreen(state)
        if isBlackScreenOn == state then return end 
        isBlackScreenOn = state
        BlackFrame.Visible = state
        
        if state then
            BlackScreenBtn.Visible = true 
            BlackScreenBtn.Text = "Black Screen: ON"
            BlackScreenBtn.BackgroundColor3 = Color3.fromRGB(150, 30, 30)
            if setfpscap then setfpscap(15) end
        else
            if Options.ShowBlackScreenBtn then
                BlackScreenBtn.Visible = Options.ShowBlackScreenBtn.Value
            end
            BlackScreenBtn.Text = "Black Screen: OFF"
            BlackScreenBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            if setfpscap then setfpscap(60) end
        end
        
        pcall(function()
            if makefolder and not isfolder("JirametHubConfig") then makefolder("JirametHubConfig") end
            if writefile then writefile("JirametHubConfig/BS_State.txt", tostring(state)) end
        end)
    end
    
    SetBlackScreenState = toggleBlackScreen

    BlackScreenBtn.MouseButton1Click:Connect(function()
        toggleBlackScreen(not isBlackScreenOn)
    end)

    ShowBlackScreenBtnToggle:OnChanged(function()
        if not isBlackScreenOn then
            BlackScreenBtn.Visible = Options.ShowBlackScreenBtn.Value
        end
        if not Options.ShowBlackScreenBtn.Value and isBlackScreenOn then
            toggleBlackScreen(false)
        end
    end)

    local AutoSaveToggle = Tabs.Settings:AddToggle("AutoSaveToggle", {Title = "Enable Auto Save (Every 2s)", Default = true })
    
    updateSavedState = function()
        for k, option in pairs(Options) do
            if type(option.Value) == "table" then
                lastSavedState[k] = {}
                for item, val in pairs(option.Value) do
                    lastSavedState[k][item] = val
                end
            else
                lastSavedState[k] = option.Value
            end
        end
    end

    local function hasConfigChanged()
        for k, option in pairs(Options) do
            if type(option.Value) == "table" then
                local oldTable = lastSavedState[k] or {}
                for item, val in pairs(option.Value) do
                    if oldTable[item] ~= val then return true end
                end
                for item, val in pairs(oldTable) do
                    if option.Value[item] ~= val then return true end
                end
            else
                if lastSavedState[k] ~= option.Value then
                    return true
                end
            end
        end
        return false
    end

    task.spawn(function()
        while true do
            task.wait(2)
            if not isConfigLoaded then continue end 
            
            if Options.AutoSaveToggle and Options.AutoSaveToggle.Value then
                if hasConfigChanged() then 
                    SaveManager:Save("AutoSaveConfig")
                    updateSavedState() 
                    Fluent:Notify({ Title = "Auto Save Successful", Content = "Settings saved automatically.", Duration = 1.5 })
                end
            end
        end
    end)
end

