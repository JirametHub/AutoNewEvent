end)

local function PerformHostWait(toggleOption)
    -- เริ่มนับเวลาเพื่อสร้างห้องเลยโดยไม่ต้องสนว่ามีลูกทีมหรือไม่ (ป้องกัน Host ค้างล็อบบี้)
    if IsHost and CurrentToken ~= "" and not HostLobbyWaitDone then
        local waitTime = tonumber(Options.HostWaitTime.Value) or 60
        Fluent:Notify({ Title = "Party System", Content = "Waiting " .. waitTime .. " seconds in Lobby before creating room...", Duration = 10 })
        
        for i = 1, waitTime do
            if i == math.floor(waitTime / 2) and waitTime > 10 then
                Fluent:Notify({ Title = "Party System", Content = "Waiting another " .. (waitTime - i) .. " seconds before creating room...", Duration = 5 })
            end
            if not toggleOption.Value or not isInLobby() then 
                return false 
            end
            task.wait(1)
        end
        HostLobbyWaitDone = true
    end
    return true
end

local function WaitBeforeStart(toggleOption)
    if IsHost and CurrentToken ~= "" then
        local startTime = tonumber(Options.HostStartTime.Value) or 5
        Fluent:Notify({ Title = "Party System", Content = "Room created! Waiting for members to join for " .. startTime .. " seconds...", Duration = 5 })
        for i = 1, startTime do
            if not toggleOption.Value or not isInLobby() then 
                return false 
            end
            task.wait(1)
        end
    else
        task.wait(1.5)
    end
    return true
end

