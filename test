-- ฟังก์ชันกลาง: เช็กและรอสมาชิกปาร์ตี้ให้ครบก่อนกด Start
-- ==========================================
local function WaitForPartyMembers()
    if IsHost and CurrentToken ~= "" and PartyData then
        local expectedMembers = #(PartyData.Members or {})
        if expectedMembers > 0 then
            local waitTime = 0
            repeat
                task.wait(1)
                waitTime = waitTime + 1
                
                -- เช็กว่าสมาชิกทุกคนอยู่ในเซิร์ฟเวอร์นี้หรือยัง
                local membersInServer = 0
                for _, memName in pairs(PartyData.Members or {}) do
                    if game:GetService("Players"):FindFirstChild(memName) then
                        membersInServer = membersInServer + 1
                    end
                end
            until membersInServer >= expectedMembers or waitTime >= 15
            
            -- หน่วงเวลาเพิ่มอีก 4 วิ เพื่อให้ลูกปาร์ตี้กดยืนยันเข้าห้อง (หรือให้ AutoJoinLeader ทำงาน)
            task.wait(4) 
        else
            task.wait(1.5)
        end
    else
        task.wait(1.5)
    end
end

