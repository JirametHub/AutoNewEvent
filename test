local function WriteFirebase(path, data)
    local requestFunc = http_request or request or HttpPost or syn.request
    if not requestFunc then return false end
    local success, res = pcall(function()
        return requestFunc({
            Url = FirebaseURL .. path .. ".json",
            Method = "PUT",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
    return success and res.StatusCode == 200
end

local function ReadFirebase(path)
    local requestFunc = http_request or request or HttpPost or syn.request
    if not requestFunc then return nil end
    local success, res = pcall(function()
        return requestFunc({ Url = FirebaseURL .. path .. ".json", Method = "GET" })
    end)
    if success and res.StatusCode == 200 and res.Body ~= "null" then
        return HttpService:JSONDecode(res.Body)
    end
    return nil
end

local function DeleteFirebase(path)
    local requestFunc = http_request or request or HttpPost or syn.request
    if not requestFunc then return false end
    local success, res = pcall(function()
        return requestFunc({ Url = FirebaseURL .. path .. ".json", Method = "DELETE" })
    end)
    return success and res.StatusCode == 200
end

