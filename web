-- ==========================================
-- ฟังก์ชันจัดรูปแบบและส่ง Webhook (ของจริงตอนจบด่าน)
-- ==========================================
local function SendRewardsToDiscord(mapName, gameStatus, totalTime, playerLevel, dropsText)
    local url = WebhookInput.Text
    if url == "" or not url:find("discord") then return end

    local requestFunc = http_request or request or HttpPost or syn.request
    if not requestFunc then return end

    local infoContent = string.format(
        "`⭐` • Username: ||%s||\n`🎊` • Level: %s\n`🌎` • Map: **%s - %s**\n`⏳` • TotalTime: **%s**\n**[ Rewards ]**\n```\n%s```",
        player.Name,
        tostring(playerLevel),
        mapName,
        gameStatus,
        totalTime,
        dropsText
    )

    local data = {
        ["embeds"] = {
            {
                ["footer"] = {
                    ["text"] = "Jiramet Hub (TH)",
                    ["icon_url"] = "https://img1.pic.in.th/images/1000091508.md.png"
                },
                ["image"] = {
                    ["url"] = ""
                },
                ["thumbnail"] = {
                    ["url"] = "https://img1.pic.in.th/images/1000091498.th.jpg"
                },
                ["author"] = {
                    ["name"] = "[🐰EVENT] Re:Rangers X",
                    ["url"] = "https://www.roblox.com/share?code=3f029d7d2a92274e969aae43736011e9&type=ExperienceDetails&stamp=1776061797166",
                    ["icon_url"] = "https://img1.pic.in.th/images/1000091498.md.jpg"
                },
                ["fields"] = {
                    {
                        ["name"] = "Information",
                        ["value"] = infoContent,
                        ["inline"] = true
                    }
                },
                ["timestamp"] = DateTime.now():ToIsoDate() -- เวลาปัจจุบัน ณ ขณะที่จบเกม
            }
        },
        ["components"] = {}
    }

    pcall(function()
        requestFunc({
            Url = url,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode(data)
        })
    end)
end

-- ==========================================
-- 3. ระบบดักจับการจบด่าน (Hooking UI & Inventory)
-- ==========================================
task.spawn(function()
    local playerGui = player:WaitForChild("PlayerGui")
    local rewardsUI = playerGui:WaitForChild("RewardsUI", 99999)
    if not rewardsUI then return end

    rewardsUI:GetPropertyChangedSignal("Enabled"):Connect(function()
        if systemActive and rewardsUI.Enabled == true then
            
            task.wait(2) -- รอสคริปต์เกมโหลดของลงหน้าจอให้เสร็จ
            
            pcall(function()
                local main = rewardsUI:FindFirstChild("Main")
                if not main then return end
                
                -- ดึงชื่อโหมดและแชปเตอร์มารวมเป็นชื่อ Map
                local modeText = main.LeftSide.Mode.Text
                local chapterText = main.LeftSide.Chapter.Text
                if chapterText == "" or chapterText == "[EMPTY]" then chapterText = "N/A" end
                local fullMapName = modeText .. " (" .. chapterText .. ")"

                -- ดึงสถานะด่าน (ตัดเครื่องหมาย ~ ออกแล้วทำให้เป็นตัวพิมพ์ใหญ่)
                local gameStatusRaw = main.LeftSide:FindFirstChild("GameStatus") and main.LeftSide.GameStatus.Text or "N/A"
                local gameStatus = gameStatusRaw:gsub("~%s*", ""):upper()

                -- ดึงเวลา
                local totalTimeRaw = main.LeftSide:FindFirstChild("TotalTime") and main.LeftSide.TotalTime.Text or "00:00:00"
                local totalTime = totalTimeRaw:gsub("Total Time:%s*", "")

                -- โหลดข้อมูลผู้เล่นผ่าน Module ของเกมเพื่อหาเลเวล
                local GetDataModule = require(ReplicatedStorage.Shared.GetData)
                local playerData = GetDataModule.GetData(player)
                
                local playerLevel = "N/A"
                if playerData and playerData:FindFirstChild("Data") and playerData.Data:FindFirstChild("Level") then
                    playerLevel = playerData.Data.Level.Value
                end

                local dropListText = ""
                local itemsList = main.LeftSide.Rewards.ItemsList
                
                for _, item in pairs(itemsList:GetChildren()) do
                    if item:IsA("GuiObject") and not item:IsA("UIComponent") then
                        pcall(function()
                            local infoFolder = item.Frame.ItemFrame.Info
                            local displayName = infoFolder.ItemsNames.Text
                            local dropAmount = infoFolder.DropAmonut.Text 
                            local systemName = item.Name 

                            local totalAmount = 0
                            if playerData then
                                if playerData:FindFirstChild("Items") and playerData.Items:FindFirstChild(systemName) then
                                    totalAmount = playerData.Items[systemName].Amount.Value
                                elseif playerData:FindFirstChild("Data") and playerData.Data:FindFirstChild(systemName) then
                                    totalAmount = playerData.Data[systemName].Value
                                end
                            end

                            local formattedTotal = FormatNumber(totalAmount)
                            dropListText = dropListText .. "- " .. displayName .. " (" .. dropAmount .. ") [Total: " .. formattedTotal .. "]\n"
                        end)
                    end
                end

                if dropListText == "" then
                    dropListText = "N/A"
                end

                -- สั่งส่ง Webhook แบบของจริง
                SendRewardsToDiscord(fullMapName, gameStatus, totalTime, playerLevel, dropListText)
            end)
        end
    end)
end)
