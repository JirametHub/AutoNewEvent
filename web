-- ฟังก์ชันใส่คอมม่าให้ตัวเลข
local function FormatNumber(n)
    if not n then return "0" end
    return tostring(math.floor(n)):reverse():gsub("%d%d%d", "%1,"):reverse():gsub("^,", "")
end

